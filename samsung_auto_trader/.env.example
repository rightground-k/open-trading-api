# KIS Open API Credentials (Mock Trading)
# 한국투자증권 모의투자 앱키를 발급받아 아래에 입력하세요.
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워주세요.

KIS_ACCOUNT=12345678
KIS_ACCOUNT_PROD=01
KIS_APPKEY=your_mock_appkey_here
KIS_APPSECRET=your_mock_appsecret_here
# 일일 주문 한도
MAX_DAILY_ORDERS=50

# Telegram Notification (Optional)
# 텔레그램 알림을 받으려면 아래 값을 채워주세요.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
